  "runs": [
    {
      "tool": {
        "driver": {
          "name": "mlsecops-agent",
          "informationUri": "https://github.com/negexx/nex-portfolio",
          "semanticVersion": "0.2.0",
          "rules": [
            {
              "id": "deserialization.unsafe-joblib-load",
              "name": "DeserializationUnsafeJoblibLoad",
              "shortDescription": {
                "text": "insecure-deserialization"
              },
              "fullDescription": {
                "text": "Detects deserialization.unsafe-joblib-load. Produced by a deterministic mlsecops-agent check; interpret severity using the security-severity property."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "security-severity": "7.5",
                "tags": [
                  "security",
                  "ml",
                  "deserialization"
                ]
              }
            },
