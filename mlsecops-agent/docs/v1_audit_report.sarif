          "ruleId": "supply_chain.untrusted-wget-source",
          "level": "warning",
          "message": {
            "text": "`!wget` downloads content with no checksum verification anywhere in the notebook (cell 1). If the upstream source changes, your pipeline runs on different bytes."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "nids_v1_baseline.ipynb"
                },
                "region": {
                  "startLine": 1,
