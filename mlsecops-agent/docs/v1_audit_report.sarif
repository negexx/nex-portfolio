          "ruleId": "leakage.label-proxy-feature",
          "level": "error",
          "message": {
            "text": "[cell 2] Column `difficulty_level` in an assignment matches a label-proxy pattern. If this column encodes the target (directly or indirectly) and is included in the feature set, the model will have access to the answer at inference time."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "nids_v1_baseline.ipynb"
                },
                "region": {
                  "startLine": 1,
                  "endLine": 12,
                  "snippet": {
                    "text": "[\n    'duration','protocol_type','service','flag','src_bytes','dst_bytes','land',\n    'wrong_fragment','urgent','hot','num_failed_logins','logged_in',\n    'num_compromised','root_shell','su_attempted'"
                  }
                }
              }
            }
          ],
          "properties": {
            "security-severity": "7.5",
            "category": "data-leakage",
            "check": "leakage"
          },
          "fixes": [
            {
              "description": {
                "text": "Confirm whether `difficulty_level` is a label proxy — this is a name-match heuristic and may be a false positive. If it is a proxy, remove it from the feature list before training."
              },
              "properties": {
                "confidence": "medium"
              }
            }
          ]
