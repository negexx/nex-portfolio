      "results": [
        {
          "ruleId": "supply_chain.unpinned-pip-install",
          "level": "warning",
          "message": {
            "text": "`!pip install imbalanced-learn` has no version pin (cell 1). Re-runs may install a different version and silently break the pipeline."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "nids_v1_baseline.ipynb"
                },
                "region": {
                  "startLine": 3,
                  "endLine": 3,
                  "snippet": {
                    "text": "!pip install imbalanced-learn -q"
                  }
                }
              }
            }
          ],
          "properties": {
            "security-severity": "5.5",
            "category": "dependency-pinning",
            "check": "supply_chain"
          },
          "fixes": [
            {
              "description": {
                "text": "Pin `imbalanced-learn` to a known-good version: `!pip install imbalanced-learn==X.Y.Z` and record it in requirements.txt / pyproject.toml."
              },
              "properties": {
                "confidence": "high"
              }
            }
          ]
        },
