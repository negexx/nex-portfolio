        {
          "ruleId": "deserialization.unsafe-numpy-load",
          "level": "warning",
          "message": {
            "text": "`numpy.load(..., allow_pickle=True)` enables pickle deserialisation in numpy arrays. The default is `False` for this reason. Save arrays in a non-pickle format (`.npy` without object arrays, `.npz`, or HDF5) so `allow_pickle` is not needed."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "nids_v1_baseline.ipynb"
                },
                "region": {
                  "startLine": 572,
                  "endLine": 572,
                  "snippet": {
                    "text": "np.load('feature_cols.npy', allow_pickle=True)"
                  }
                }
              }
            }
          ],
          "properties": {
            "security-severity": "5.5",
            "category": "insecure-deserialization",
            "check": "deserialization"
          },
          "fixes": [
            {
              "description": {
                "text": "Remove `allow_pickle=True` and resave the array without object dtype. If the array contains objects you control, switch to a typed format or use `numpy.savez` with a schema you verify."
              },
              "properties": {
                "confidence": "high"
              }
            }
          ]
        },
        {
          "ruleId": "deserialization.unsafe-joblib-load",
          "level": "error",
          "message": {
            "text": "`joblib.load` uses pickle internally and will execute arbitrary code when loading a maliciously crafted file. Replace with a safe format (e.g. safetensors, JSON, ONNX) or verify the file's integrity with a cryptographic hash before loading."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "nids_v1_baseline.ipynb"
                },
                "region": {
                  "startLine": 573,
                  "endLine": 573,
                  "snippet": {
                    "text": "joblib.load('label_encoder.pkl')"
                  }
                }
              }
            }
          ],
          "properties": {
            "security-severity": "7.5",
            "category": "insecure-deserialization",
            "check": "deserialization"
          },
          "fixes": [
            {
              "description": {
                "text": "Replace `joblib.load` with a safe serialisation format such as `safetensors` or save/load model weights to JSON/ONNX. If you must use joblib, pin the exact file hash in your pipeline and verify it before `load`."
              },
              "properties": {
                "confidence": "high"
              }
            }
          ]
        },
