{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(uv run *)",
      "Bash(uv tool *)",
      "Bash(uv lock)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(bandit *)",
      "Bash(detect-secrets *)",
      "Bash(pip-audit *)",
      "Bash(safety *)",
      "Bash(semgrep *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pkl)",
      "Read(**/*.h5)",
      "Read(**/*.pt)",
      "Read(**/*.pth)",
      "Read(**/*.safetensors)",
      "Bash(python -c *pickle*)",
      "Bash(python -c *joblib.load*)"
    ]
  },
  "env": {
    "FORCE_COLOR": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
