# Copy to .env.local (gitignored) and fill in.

# LLM access — prefer AI Gateway for observability + fallback; direct Anthropic as backup.
ANTHROPIC_API_KEY=sk-ant-...
AI_GATEWAY_KEY=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sandbox — Vercel Sandbox (preferred) or e2b
VERCEL_SANDBOX_TOKEN=
E2B_API_KEY=

# Storage
MLSECOPS_DB_PATH=./runs/mlsecops.sqlite
