# mlsecops-agent - example environment.
# Copy to .env.local and fill in real values. .env* is gitignored.

# --- LLM backend (DeepSeek via OpenAI-compatible API) ---
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Default model for orchestration + fix narration. ~$0.14 in / $0.28 out per 1M tokens.
DEEPSEEK_MODEL_DEFAULT=deepseek-v4-flash
# Escalation model for leakage AST-judgement + adversarial strategy.
DEEPSEEK_MODEL_HARD=deepseek-v4-pro
# Override base URL for OpenRouter fallback, on-prem, or local stub.
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Observability (optional) ---
# https://langfuse.com/ - leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Sandbox (W3+ planned) ---
# Vercel Sandbox or e2b - for executing target ML code in isolation.
VERCEL_TOKEN=
E2B_API_KEY=
